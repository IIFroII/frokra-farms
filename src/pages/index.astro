---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout title="Frokra Farms">

<Navbar />

<section class="min-h-screen flex items-center justify-center">

    <div class="text-center">

        <h1 class="text-7xl font-black text-green-800 mb-6">
            FROKRA FARMS
        </h1>

        <p class="text-2xl text-gray-700 mb-10">
            Fresh From Our Fields To Your Table
        </p>

        <div class="flex justify-center gap-6">

            <a
                href="/produce"
                class="bg-green-700 hover:bg-green-800 text-white px-8 py-4 rounded-xl transition">

                Shop Produce

            </a>

            <a
                href="/about"
                class="border-2 border-green-700 text-green-700 px-8 py-4 rounded-xl">

                Our Story

            </a>

        </div>

    </div>

</section>

</Layout>