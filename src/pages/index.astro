---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import FeatureCard from "../components/FeatureCard.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import okraGrowthStages from "../assets/okra-growth-stages.png";
---

<Layout title="Frokra Farms | Okra With Character">
  <Navbar />
  <main>
    <Hero />

    <section aria-label="Frokra values" class="overflow-hidden bg-[#173f2a] py-5 text-[#f6f0df]">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-8 gap-y-2 px-5 text-center text-xs font-black uppercase tracking-[0.18em] lg:px-8">
        <span>Grown with care</span><span class="text-[#b8cf78]" aria-hidden="true">◆</span>
        <span>Harvested for flavor</span><span class="text-[#b8cf78]" aria-hidden="true">◆</span>
        <span>Packed fresh</span><span class="text-[#b8cf78]" aria-hidden="true">◆</span>
        <span>Proudly Frokra</span>
      </div>
    </section>

    <section id="produce" class="bg-[#fffdf7] px-5 py-24 lg:px-8 lg:py-32">
      <div class="mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-2 lg:gap-20">
        <div class="group relative mx-auto w-full max-w-xl">
          <div class="absolute -inset-3 -rotate-2 rounded-[2.5rem] bg-[#b8cf78]/45 transition-transform duration-500 group-hover:-rotate-1"></div>
          <div class="relative overflow-hidden rounded-[2.15rem] border-4 border-[#173f2a] bg-[#f6f0df] shadow-[0_26px_65px_rgba(23,63,42,.18)]">
            <Image
              src={okraGrowthStages}
              alt="Okra growing at Frokra Farms, progressing from young plants to blossom to mature crop"
              widths={[480, 720, 960, 1536]}
              sizes="(min-width: 1024px) 44vw, 92vw"
              format="webp"
              quality={88}
              class="block h-auto w-full transition duration-700 group-hover:scale-[1.015]"
            />
          </div>

          <div class="absolute left-5 top-5 rounded-full border border-[#173f2a]/10 bg-[#fffdf7]/95 px-4 py-2 text-[.65rem] font-black uppercase tracking-[0.16em] text-[#2f6f45] shadow-md backdrop-blur">
            Farm favorite
          </div>

          <div class="mt-5 grid grid-cols-3 gap-2" aria-label="Okra growth stages">
            <div class="rounded-xl bg-[#173f2a] px-3 py-3 text-center text-white">
              <span class="block text-[.55rem] font-black uppercase tracking-[0.18em] text-[#b8cf78]">Stage 01</span>
              <span class="font-display text-sm font-bold sm:text-base">Growing</span>
            </div>
            <div class="rounded-xl bg-[#173f2a] px-3 py-3 text-center text-white">
              <span class="block text-[.55rem] font-black uppercase tracking-[0.18em] text-[#b8cf78]">Stage 02</span>
              <span class="font-display text-sm font-bold sm:text-base">Blossom</span>
            </div>
            <div class="rounded-xl bg-[#173f2a] px-3 py-3 text-center text-white">
              <span class="block text-[.55rem] font-black uppercase tracking-[0.18em] text-[#b8cf78]">Stage 03</span>
              <span class="font-display text-sm font-bold sm:text-base">Crop</span>
            </div>
          </div>
        </div>

        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em] text-[#9b5f3f]">Meet the main crop</p>
          <h2 class="font-display mt-5 text-5xl font-bold leading-[.95] tracking-[-0.05em] text-[#173f2a] md:text-7xl">
            Fresh from our fields to your table.
          </h2>
          <p class="mt-7 max-w-xl text-lg leading-8 text-[#173f2a]/65">
            Fried golden, simmered in gumbo, tossed on the grill, or added to a family recipe—
            good okra earns its place at the table. Ours is selected for the texture, color,
            and flavor that make every dish better.
          </p>
          <dl class="mt-10 grid grid-cols-2 gap-4">
            <div class="rounded-2xl border border-[#173f2a]/10 p-5">
              <dt class="text-xs font-black uppercase tracking-wider text-[#173f2a]/50">Picked for</dt>
              <dd class="font-display mt-1 text-2xl font-bold text-[#173f2a]">Freshness</dd>
            </div>
            <div class="rounded-2xl border border-[#173f2a]/10 p-5">
              <dt class="text-xs font-black uppercase tracking-wider text-[#173f2a]/50">Packed with</dt>
              <dd class="font-display mt-1 text-2xl font-bold text-[#173f2a]">Care</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <section id="story" class="paper-noise bg-[#f6f0df] px-5 py-24 lg:px-8 lg:py-32">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-10 lg:grid-cols-[.8fr_1.2fr] lg:gap-20">
          <div>
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[#9b5f3f]">Why Frokra Farms</p>
            <h2 class="font-display mt-5 text-5xl font-bold leading-none tracking-[-0.045em] text-[#173f2a] md:text-6xl">
              Big flavor starts with small details.
            </h2>
          </div>
          <p class="max-w-2xl self-end text-lg leading-8 text-[#173f2a]/65">
            We’re building a farm brand around something simple: grow good food, treat it with
            care, and make fresh produce feel every bit as joyful as it tastes.
          </p>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-3">
          <FeatureCard number="01" title="Fresh first" text="Quality starts in the field and stays front and center through every step after harvest." />
          <FeatureCard number="02" title="Picked with purpose" text="We focus on the color, tenderness, and texture that turn good okra into a great meal." />
          <FeatureCard number="03" title="Made memorable" text="From our name to our packaging, Frokra brings real personality to the produce aisle." />
        </div>
      </div>
    </section>

    <section id="recipes" class="bg-[#9b5f3f] px-5 py-24 text-white lg:px-8 lg:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-12 md:grid-cols-[1.05fr_.95fr]">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em] text-[#f0d7bc]">From the Frokra kitchen</p>
          <h2 class="font-display mt-5 max-w-2xl text-5xl font-bold leading-[.95] tracking-[-0.05em] md:text-7xl">
            Bring something fresh to the table.
          </h2>
        </div>
        <div class="rounded-[2rem] border border-white/20 bg-white/10 p-7 backdrop-blur sm:p-9">
          <p class="font-display text-3xl font-bold">Recipes are growing.</p>
          <p class="mt-3 leading-7 text-white/75">
            Crispy favorites, Southern classics, weeknight sides, and new ways to love okra are coming soon.
          </p>
          <span class="mt-7 inline-flex rounded-full bg-[#f6f0df] px-5 py-3 text-sm font-black text-[#9b5f3f]">
            Fresh ideas coming soon
          </span>
        </div>
      </div>
    </section>

    <section id="wholesale" class="paper-noise bg-[#b8cf78] px-5 py-24 lg:px-8 lg:py-28">
      <div class="mx-auto max-w-5xl text-center">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-[#173f2a]/60">For markets, grocers & kitchens</p>
        <h2 class="font-display mt-5 text-5xl font-bold leading-[.95] tracking-[-0.05em] text-[#173f2a] md:text-7xl">
          Let’s grow something good together.
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-[#173f2a]/70">
          Frokra Farms is preparing for retail and wholesale partnerships. Full availability and ordering details will be shared here as we grow.
        </p>
        <a href="#contact" class="mt-9 inline-flex rounded-full bg-[#173f2a] px-7 py-4 font-black text-white transition hover:-translate-y-1 hover:bg-[#2f6f45]">
          Partnership information
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
