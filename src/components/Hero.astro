<section class="paper-noise relative overflow-hidden bg-[#f6f0df]">
  <div class="pointer-events-none absolute -left-24 top-24 size-72 rounded-full bg-[#b8cf78]/30 blur-3xl"></div>
  <div class="pointer-events-none absolute -right-24 bottom-0 size-80 rounded-full bg-[#9b5f3f]/10 blur-3xl"></div>

  <div class="mx-auto grid min-h-[calc(100vh-74px)] max-w-7xl items-center gap-8 px-5 py-16 lg:grid-cols-[.9fr_1.1fr] lg:px-8 lg:py-20">
    <div class="relative z-10">
      <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#173f2a]/15 bg-white/50 px-4 py-2 text-xs font-black uppercase tracking-[0.2em] text-[#2f6f45]">
        <span class="size-2 rounded-full bg-[#76a85b]"></span>
        Rooted in freshness
      </p>

      <h1 class="font-display max-w-3xl text-[clamp(3.7rem,8vw,7.2rem)] font-bold leading-[0.83] tracking-[-0.065em] text-[#173f2a]">
        Okra with
        <span class="relative mt-2 block w-fit text-[#9b5f3f]">
          character.
          <svg class="absolute -bottom-4 left-1 w-full" viewBox="0 0 340 18" fill="none" aria-hidden="true">
            <path d="M3 12C81 2 196 2 337 8" stroke="#76a85b" stroke-width="7" stroke-linecap="round"/>
          </svg>
        </span>
      </h1>

      <p class="mt-10 max-w-xl text-lg leading-8 text-[#173f2a]/75 md:text-xl">
        Fresh, crisp, and proudly homegrown. Frokra Farms brings premium okra
        from our fields to family tables, neighborhood markets, and store shelves.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a href="#produce" class="rounded-full bg-[#173f2a] px-7 py-4 font-black text-white shadow-[0_12px_30px_rgba(23,63,42,.18)] transition hover:-translate-y-1 hover:bg-[#2f6f45]">
          Meet our okra
        </a>
        <a href="#story" class="group inline-flex items-center gap-2 px-3 py-4 font-black text-[#173f2a]">
          Our growing story
          <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-12 flex flex-wrap gap-x-8 gap-y-4 border-t border-[#173f2a]/15 pt-6">
        <p class="text-sm font-bold text-[#173f2a]/65"><span class="mr-2 text-[#2f6f45]">✓</span>Picked for quality</p>
        <p class="text-sm font-bold text-[#173f2a]/65"><span class="mr-2 text-[#2f6f45]">✓</span>Packed with care</p>
        <p class="text-sm font-bold text-[#173f2a]/65"><span class="mr-2 text-[#2f6f45]">✓</span>Full of flavor</p>
      </div>
    </div>

    <div class="relative isolate mx-auto mt-4 w-full max-w-[680px] pb-2 pt-12 lg:mt-0">
      <div class="mascot-reveal">
        <div class="mascot-idle mascot-rig relative z-10">
          <img
            class="mascot-base h-auto w-full drop-shadow-[0_30px_24px_rgba(23,63,42,.24)]"
            src="/images/frokra-mascot.webp"
            alt="Fro, the Frokra Farms mascot, holding two freshly harvested bundles of okra"
            width="1404"
            height="1120"
            loading="eager"
            fetchpriority="high"
          />

          <img class="mascot-layer mascot-hair" src="/images/frokra-mascot.webp" alt="" aria-hidden="true" />
          <img class="mascot-layer mascot-arm-left" src="/images/frokra-mascot.webp" alt="" aria-hidden="true" />
          <img class="mascot-layer mascot-arm-right" src="/images/frokra-mascot.webp" alt="" aria-hidden="true" />
          <img class="mascot-layer mascot-flower mascot-flower-left" src="/images/frokra-mascot.webp" alt="" aria-hidden="true" />
          <img class="mascot-layer mascot-flower mascot-flower-right" src="/images/frokra-mascot.webp" alt="" aria-hidden="true" />
          <span class="mascot-name-label" aria-hidden="true">Fro</span>
        </div>
      </div>
    </div>
  </div>
</section>
