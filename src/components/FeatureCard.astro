---
interface Props {
  number: string;
  title: string;
  text: string;
}

const { number, title, text } = Astro.props;
---

<article class="group rounded-[2rem] border border-[#173f2a]/10 bg-[#fffdf7] p-7 transition duration-300 hover:-translate-y-2 hover:shadow-[0_24px_60px_rgba(23,63,42,.12)] md:p-8">
  <div class="mb-10 flex size-12 items-center justify-center rounded-full bg-[#b8cf78]/35 font-display text-lg font-bold text-[#173f2a] transition-colors group-hover:bg-[#173f2a] group-hover:text-white">
    {number}
  </div>
  <h3 class="font-display text-3xl font-bold tracking-tight text-[#173f2a]">{title}</h3>
  <p class="mt-3 leading-7 text-[#173f2a]/65">{text}</p>
</article>
