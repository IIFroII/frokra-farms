---
const links = [
  { href: "#produce", label: "Our Okra" },
  { href: "#story", label: "Our Story" },
  { href: "#recipes", label: "Kitchen" },
];
---

<header class="sticky top-0 z-50 border-b border-[#173f2a]/10 bg-[#f6f0df]/90 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8" aria-label="Main navigation">
    <a href="/" class="group flex items-center gap-3" aria-label="Frokra Farms home">
      <span class="grid size-10 place-items-center overflow-hidden rounded-full bg-[#9b5f3f] p-1 transition-transform group-hover:-rotate-6">
        <img
          src="/images/frokra-botanical-emblem.webp"
          alt=""
          aria-hidden="true"
          width="32"
          height="32"
          class="size-full object-contain"
        />
      </span>
      <span>
        <span class="block text-[1.35rem] font-black leading-none tracking-[-0.04em] text-[#173f2a]">FROKRA</span>
        <span class="block text-[0.63rem] font-bold tracking-[0.34em] text-[#9b5f3f]">FARMS</span>
      </span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a class="text-sm font-bold text-[#173f2a]/75 transition-colors hover:text-[#173f2a]" href={link.href}>
            {link.label}
          </a>
        ))
      }
      <a href="#wholesale" class="rounded-full bg-[#173f2a] px-5 py-3 text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-[#2f6f45]">
        Wholesale
      </a>
    </div>

    <details class="relative md:hidden">
      <summary class="grid size-11 cursor-pointer list-none place-items-center rounded-full border border-[#173f2a]/20 text-[#173f2a]" aria-label="Open navigation menu">
        <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </summary>
      <div class="absolute right-0 top-14 w-56 rounded-2xl border border-[#173f2a]/10 bg-[#fffdf7] p-3 shadow-xl">
        {
          links.map((link) => (
            <a class="block rounded-xl px-4 py-3 font-bold text-[#173f2a] hover:bg-[#b8cf78]/20" href={link.href}>
              {link.label}
            </a>
          ))
        }
        <a href="#wholesale" class="mt-2 block rounded-xl bg-[#173f2a] px-4 py-3 text-center font-bold text-white">
          Wholesale
        </a>
      </div>
    </details>
  </nav>
</header>
